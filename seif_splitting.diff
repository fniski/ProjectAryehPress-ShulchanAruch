 def _build_measurement_tex(
     text: str,
     width_pt: float,
     font_size: float,
     leading: float,
     font_dir: str = "",
     font_file: str = "",
 ) -> str:
     """
     Build a minimal TeX document that renders `text` in a parbox of the given width.
     We compile this to XDV and count the lines.
     """
     preamble = r"""
 \documentclass[11pt]{article}
 \usepackage[a4paper, margin=1in]{geometry}
 \usepackage{fontspec}
 \usepackage{polyglossia}
 \setdefaultlanguage{hebrew}
+\setotherlanguage{english}
 \pagenumbering{gobble}
 \newfontfamily\measurefont[
     Path=D:/Projects/ProjectAryehPress/Seforim/Fonts/,
     Extension=.otf,
     UprightFont=*-Medium,
     BoldFont=*-Bold,
     ItalicFont=*-MediumOblique,
     BoldItalicFont=*-BoldOblique
 ]{FrankRuehlCLM}
 \measurefont
 """
     body = f"""
 \\begin{{document}}
 \\fontsize{{{font_size}}}{{{leading}}}\\selectfont
 \\parbox{{{width_pt}pt}}{{ {text} }}
 \\end{{document}}
 """
     return preamble + body
 
